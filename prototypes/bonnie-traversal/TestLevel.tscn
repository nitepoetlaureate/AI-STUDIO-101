; =============================================================================
; ZONE 8: NARROW SQUEEZE GAP
; A ceiling slab floating over the main ground, creating a 32px tall passage
; BONNIE height = 48px (capsule: radius=8, height=32, total=48)
; Passage height = 32px < 48px → SQUEEZING state auto-triggers
;
; Main ground continues as floor.
; Ceiling slab: 200px wide × 68px tall
;   Slab bottom at y=468 (ground surface at y=500, passage = 32px)
;   Slab top at y=400
;   StaticBody2D center: (3300, 434)
;
; Approach ramp (left, 100px wide, at y=468 top): bridges ground to squeeze entry
;   Center: (3190, 476) — this sits on top of main ground, raising floor to y=468
;   Creates the squeeze "tunnel" with raised floor + ceiling overhead
;
; Exit ramp (right, same): mirrors approach
;   Center: (3410, 476)
;
; Dark gray to signal enclosed/dangerous passage
; =============================================================================

; SqueezeCeiling — the ceiling slab. Ground at y=500, ceiling bottom at y=468 = 32px passage.
; BONNIE normal shape (48px) can't fit. Squeeze shape (20px) fits with 12px clearance.
[node name="SqueezeCeiling" type="StaticBody2D" parent="."]
position = Vector2(3300, 434)

[node name="CollisionShape2D" type="CollisionShape2D" parent="SqueezeCeiling"]
shape = SubResource("Shape_SqueezeCeil")

[node name="ColorRect" type="ColorRect" parent="SqueezeCeiling"]
offset_left = -100.0
offset_top = -34.0
offset_right = 100.0
offset_bottom = 34.0
color = Color(0.3, 0.3, 0.3, 1.0)

; SqueezeTrigger — covers full approach + passage + exit (x=3050 to x=3550).
; body_entered → _squeeze_zone_active = true → enter SQUEEZING (20px shape, sprite shrinks).
; body_exited  → _squeeze_zone_active = false → exit SQUEEZING (48px shape restored).
; CollisionLayer=0 (no physics presence), CollisionMask=1 (detects BONNIE layer 1).
[node name="SqueezeTrigger" type="Area2D" parent="." groups=["SqueezeTrigger"]]
position = Vector2(3300, 485)
collision_layer = 0
collision_mask = 1

[node name="CollisionShape2D" type="CollisionShape2D" parent="SqueezeTrigger"]
shape = SubResource("Shape_SqueezeTrigger")

