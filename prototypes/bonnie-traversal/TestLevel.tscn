; TestLevel.tscn — BONNIE Traversal Prototype Test Level
; Godot 4.6 | prototypes/bonnie-traversal/
; Reference: design/gdd/bonnie-traversal.md §3 and §7
;
; Layout (left to right, ground at y=500):
;   Zone 1: Flat Run Corridor        x=0–2200
;   Zone 2: Platform Steps (hop/jump/double-jump heights)
;   Zone 3: Hard Drop Zone           x=950–1250  (284px drop → ROUGH_LANDING)
;   Zone 4: Soft Drop Zone           x=1350–1650 (same height, soft_landing group)
;   Zone 5: Ledge Parry Practice     x=1750–2500
;   Zone 6: Climbable Wall           x=2600–2900 (Climbable group, brown)
;   Zone 7: Smooth Wall              x=3000–3200 (NOT Climbable, blue-gray)
;   Zone 8: Squeeze Gap              x=3250–3550 (32px passage)
;   Zone 9: Collision Objects        x=400–800   (RigidBody2D boxes in run corridor)
;   Zone 10: End Wall                x=3800      (DAZED test — slide into at speed)
;
; BONNIE spawn: (100, 476) — standing on main ground, start of run corridor
; Total level: 4000×800px (wider and taller than 720×540 viewport)

[gd_scene load_steps=12 format=3 uid="uid://test_level_traversal"]

[ext_resource type="PackedScene" path="res://prototypes/bonnie-traversal/BonnieController.tscn" id="1_bonnie"]

