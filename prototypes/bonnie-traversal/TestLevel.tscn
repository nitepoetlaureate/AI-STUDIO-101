; =============================================================================
; ZONE 2: PLATFORM STEPS
; Tests hop height, full jump height, double jump requirement
;
; Measurements (g=980 px/s²):
;   hop_velocity=280  → max height = v²/(2g) ≈ 40px above launch point
;   jump_velocity=480 → max height ≈ 118px above launch point
;   double_jump adds ≈ 74px from apex of first jump
;
; Platform A: top at y=460 (40px above ground y=500) — hop barely clears
; Platform B: top at y=410 (90px above ground)      — full jump required
; Platform C: top at y=300 (200px above ground)     — double jump required
;
; Each platform: 200px wide × 16px thick
; Horizontal positions spread for easy approach: A@x=400, B@x=650, C@x=900
; StaticBody2D positioned at slab center: (x, top+8)
; =============================================================================

[node name="PlatformA" type="StaticBody2D" parent="."]
position = Vector2(400, 468)

[node name="CollisionShape2D" type="CollisionShape2D" parent="PlatformA"]
shape = SubResource("Shape_PlatStd")

[node name="ColorRect" type="ColorRect" parent="PlatformA"]
offset_left = -100.0
offset_top = -8.0
offset_right = 100.0
offset_bottom = 8.0
color = Color(0.4, 0.4, 0.4, 1.0)

